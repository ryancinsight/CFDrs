-                    let y = j as f64 * dy;
-                    solver.temperature[i][j] = 300.0
-                        + 50.0
-                            * (std::f64::consts::PI * x).sin()
-                            * (std::f64::consts::PI * y).cos();
-                }
-            }
-
-            // Set up boundary conditions
-            let mut boundary_conditions = HashMap::new();
-            for j in 0..n {
-                let x_left = 0.0;
